generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String
  phoneNumber    String
  englishLevel   String          // "beginner" | "intermediate"
  timezone       String          // IANA e.g. "Asia/Seoul"
  createdAt      DateTime        @default(now())
  schedules      Schedule[]
  sessions       Session[]
  feedbacks      Feedback[]
  learnerProfile LearnerProfile?
}

model Schedule {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  daysOfWeek Int[]     // [1,2,3,4,5,6,7] Mon=1..Sun=7
  timeHHMM   String    // "09:00"
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  sessions   Session[]
}

model Session {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleId   String?
  schedule     Schedule?   @relation(fields: [scheduleId], references: [id])
  status       String      @default("scheduled") // "scheduled"|"in_progress"|"completed"|"failed"|"missed"
  vapiCallId   String?     @unique
  startedAt    DateTime?
  endedAt      DateTime?
  durationSecs Int?
  feedbackError String?    // null = ok/pending; "transcript_too_short" | error message when generation failed
  createdAt    DateTime    @default(now())
  transcript   Transcript?
  feedback     Feedback?
}

model Transcript {
  id        String   @id @default(cuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  content   Json     // [{role, text, timestamp}]
  rawText   String   @db.Text
  createdAt DateTime @default(now())
}

model Feedback {
  id               String   @id @default(cuid())
  sessionId        String   @unique
  session          Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  opicLevel        String   // OPIc: NL, NM, NH, IL, IM1, IM2, IM3, IH, AL, AM, AH, Superior
  opicRationale    String   @db.Text
  strengths        String   @db.Text
  improvements     String   @db.Text
  specificExamples Json     // [{original, corrected, note}]
  overallSummary   String   @db.Text
  createdAt        DateTime @default(now())
}

model LearnerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  learnerProfile   Json     // { name, level, english_level_notes, occupation, location, interests[], recurring_topics[], language_goals }
  speakingPatterns Json     // { common_errors[], improvement_areas[], strengths[], filler_words[] }
  sessionHistory   Json     // SessionEntry[] — cap 10 FIFO
  openThreads      Json     // string[] — cap 5 FIFO
  excludedTopics   Json     // string[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DailyBriefing {
  id                   String   @id @default(cuid())
  date                 String   @unique // YYYY-MM-DD (KST)
  weatherSeoul         String
  items                Json     // BriefingItem[] { category, headline, context, why_relevant }
  conversationStarters Json     // string[]
  generatedAt          DateTime @default(now())
}
