# Database
DATABASE_URL="postgresql://user:password@localhost:5432/calling_language"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-long-random-secret"

# Vapi.ai — server-side (used by /api/calls/trigger/pstn and the webhook verifier)
VAPI_API_KEY="your-vapi-api-key"
VAPI_ASSISTANT_ID="your-vapi-assistant-id"
VAPI_PHONE_NUMBER_ID="your-vapi-phone-number-id"
VAPI_WEBHOOK_SECRET="your-vapi-webhook-secret"

# Vapi.ai — client-side (used by Vapi Web SDK for in-browser WebRTC calls)
# Public key is a different credential from VAPI_API_KEY; create it in Vapi dashboard.
NEXT_PUBLIC_VAPI_PUBLIC_KEY="your-vapi-public-key"
NEXT_PUBLIC_VAPI_ASSISTANT_ID="your-vapi-assistant-id"

# Anthropic (Claude) — used for call feedback (Sonnet 4.6) and learner-profile / news-briefing summarization (Haiku 4.5)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Tavily (news search for daily briefing) — https://tavily.com, free tier 1000 searches/month
TAVILY_API_KEY="your-tavily-api-key"

# Cron — shared secret sent as Bearer token by cron-job.org to /api/cron/* endpoints
CRON_SECRET="change-me-to-a-long-random-secret"

# Admin — comma-separated emails with admin access
ADMIN_EMAILS="you@example.com"

# App
API_PORT=3001
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
